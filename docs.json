{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Dollr Developer Docs",
  "description": "Official API documentation for Dollr — accept payments, send payouts, and move money across Africa with a single unified API.",
  "theme": "mint",
  "logo": {
    "light": "/assets/logo.png",
    "dark": "/assets/logo.png",
    "href": "/"
  },
  "favicon": "/assets/favicon.png",
  "colors": {
    "primary": "#082255",
    "light": "#1a4080",
    "dark": "#051840"
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "decoration": "gradient"
  },
  "banner": {
    "content": "Dollr v1 is live — mobile money and card payments. [Get your API keys →](https://merchant.heydollr.app)"
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Merchant Dashboard",
      "href": "https://merchant.heydollr.app"
    }
  },
  "api": {
    "openapi": "https://api.heydollr.app/openapi.json",
    "playground": {
      "display": "interactive",
      "proxy": false
    },
    "examples": {
      "languages": ["bash", "python", "javascript", "php"]
    }
  },
  "interaction": {
    "drilldown": false
  },
  "contextual": {
    "display": "header",
    "options": [
      "copy",
      "view",
      {
        "title": "AI & MCP guide",
        "description": "llms.txt, MCP setup, and agent guardrails for Dollr integrations",
        "icon": "robot",
        "href": "/reference/ai-context"
      },
      "claude",
      "chatgpt"
    ]
  },
  "metadata": {
    "timestamp": true
  },
  "navigation": {
    "anchors": [
      {
        "anchor": "Merchant Dashboard",
        "icon": "gauge",
        "url": "https://merchant.heydollr.app"
      },
      {
        "anchor": "Help Center",
        "icon": "life-ring",
        "url": "https://dollr.tawk.help"
      },
      {
        "anchor": "Status & incidents",
        "icon": "signal",
        "url": "/reference/status-and-incidents"
      },
      {
        "anchor": "OpenAPI Spec",
        "icon": "braces",
        "url": "https://api.heydollr.app/openapi.json"
      },
      {
        "anchor": "Build with AI",
        "icon": "sparkles",
        "url": "/vibe-coding"
      }
    ],
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": [
              "index",
              "quickstart",
              "guides/choose-integration",
              "authentication",
              "api-conventions"
            ]
          },
          {
            "group": "Guides",
            "icon": "map",
            "pages": [
              "guides/payout-with-nodejs",
              "guides/collect-via-checkout",
              "guides/integration",
              "guides/realtime-status",
              "guides/error-handling"
            ]
          },
          {
            "group": "Concepts",
            "icon": "lightbulb",
            "pages": [
              "concepts/parties-and-counterparties",
              "concepts/sessions-and-executions",
              "api/invoices",
              "api/orders",
              "api/checkouts",
              "api/sessions",
              "api/executions",
              "api/status",
              "api/payment-accounts",
              "api/links",
              "api/predictions",
              "api/fees",
              "api/merchants",
              "api/realtime-keys"
            ]
          },
          {
            "group": "API Concepts",
            "icon": "square-terminal",
            "pages": [
              "api/parties",
              "api/counterparties"
            ]
          },
          {
            "group": "Explore",
            "icon": "folder-tree",
            "expanded": false,
            "pages": [
              {
                "group": "Integrate by stack",
                "icon": "code",
                "expanded": false,
                "pages": [
                  "guides/collect-with-nodejs",
                  "guides/collect-with-python",
                  "guides/collect-with-django",
                  "guides/collect-with-ruby",
                  "guides/collect-with-php",
                  "guides/collect-with-java",
                  "guides/collect-with-go",
                  "guides/collect-with-rust",
                  "guides/collect-with-dotnet",
                  "guides/collect-with-nextjs",
                  "guides/collect-with-laravel"
                ]
              },
              {
                "group": "Knowledge Base",
                "icon": "circle-question",
                "expanded": false,
                "pages": [
                  "knowledge-base/index",
                  "knowledge-base/invalid-credentials-401",
                  "knowledge-base/forbidden-403-unverified",
                  "knowledge-base/validation-422",
                  "knowledge-base/duplicate-reference-id",
                  "knowledge-base/session-expired-or-invalid",
                  "knowledge-base/payment-processing-status",
                  "knowledge-base/rate-limit-429",
                  "knowledge-base/server-error-5xx",
                  "reference/error-catalog",
                  "guides/error-handling"
                ]
              },
              {
                "group": "Resources",
                "icon": "book-open",
                "expanded": false,
                "pages": [
                  "reference/payments-by-market",
                  "reference/status-and-incidents",
                  "reference/examples",
                  "reference/ai-context",
                  "reference/sdks",
                  "reference/glossary",
                  "reference/support"
                ]
              }
            ]
          }
        ]
      },
      {
        "tab": "Build with AI",
        "icon": "sparkles",
        "groups": [
          {
            "group": "Vibe Coding",
            "icon": "sparkles",
            "pages": [
              "vibe-coding/index",
              "vibe-coding/start-here",
              "vibe-coding/prompt-library"
            ]
          },
          {
            "group": "Integrate by stack",
            "icon": "code",
            "expanded": false,
            "pages": [
              "guides/collect-with-nodejs",
              "guides/collect-with-python",
              "guides/collect-with-django",
              "guides/collect-with-ruby",
              "guides/collect-with-php",
              "guides/collect-with-java",
              "guides/collect-with-go",
              "guides/collect-with-rust",
              "guides/collect-with-dotnet",
              "guides/collect-with-nextjs",
              "guides/collect-with-laravel"
            ]
          },
          {
            "group": "AI resources",
            "icon": "robot",
            "expanded": false,
            "pages": [
              "reference/ai-context",
              "reference/examples",
              "guides/payout-with-nodejs",
              "knowledge-base/index"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Endpoints",
            "openapi": "https://api.heydollr.app/openapi.json"
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "website": "https://heydollr.app"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Merchant Dashboard", "href": "https://merchant.heydollr.app" },
          { "label": "Help Center", "href": "https://dollr.tawk.help" }
        ]
      },
      {
        "header": "Developers",
        "items": [
          { "label": "Quick Start", "href": "/quickstart" },
          { "label": "Build with AI", "href": "/vibe-coding" },
          { "label": "Collect with Node.js", "href": "/guides/collect-with-nodejs" },
          { "label": "Payments by Market", "href": "/reference/payments-by-market" },
          { "label": "Knowledge Base", "href": "/knowledge-base" },
          { "label": "Error Catalog", "href": "/reference/error-catalog" },
          { "label": "OpenAPI Spec", "href": "https://api.heydollr.app/openapi.json" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search the docs..."
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Dollr Developer Docs",
      "og:type": "website",
      "twitter:card": "summary_large_image"
    }
  },
  "redirects": [
    { "source": "/docs/index", "destination": "/" },
    { "source": "/docs/quickstart", "destination": "/quickstart" },
    { "source": "/docs/api/:path*", "destination": "/api/:path*" },
    { "source": "/docs/guides/:path*", "destination": "/guides/:path*" },
    { "source": "/docs/reference/:path*", "destination": "/reference/:path*" },
    { "source": "/docs/authentication", "destination": "/authentication" },
    { "source": "/docs/api-conventions", "destination": "/api-conventions" },
    { "source": "/docs/concepts/:path*", "destination": "/concepts/:path*" },
    { "source": "/docs/knowledge-base/:path*", "destination": "/knowledge-base/:path*" },
    { "source": "/docs/vibe-coding/:path*", "destination": "/vibe-coding/:path*" }
  ],
  "errors": {
    "404": {
      "redirect": false,
      "title": "Page not found",
      "description": "This page doesn't exist. Head to the [introduction](/) or [quick start](/quickstart)."
    }
  }
}
